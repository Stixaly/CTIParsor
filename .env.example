# ---------------------------------------------------------------------------
# LLM Provider — choose one: anthropic | mistral | ollama
# ---------------------------------------------------------------------------
LLM_PROVIDER=anthropic

# Per-request timeout for LLM API calls (seconds).
# If the server doesn't respond within this time the chunk is skipped and the
# pipeline continues.  Raise for large Ollama models on slow hardware.
LLM_TIMEOUT=120

# ---------------------------------------------------------------------------
# Anthropic (default)
# Get your key at: https://console.anthropic.com/
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---------------------------------------------------------------------------
# Mistral AI
# Get your key at: https://console.mistral.ai/
# Models: mistral-small-latest | mistral-medium-latest | mistral-large-latest
# ---------------------------------------------------------------------------
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest

# ---------------------------------------------------------------------------
# Ollama (self-hosted — FREE, zero API costs, runs fully local)
# Install: https://ollama.ai  then pull a model before first use.
#
# Recommended models for CTI extraction (best → fastest):
#   mistral-nemo   ~7 GB  — best JSON adherence, handles long CTI reports well
#   mistral        ~4 GB  — excellent quality/size ratio, good structured output
#   llama3.2       ~2 GB  — fastest, adequate for short reports
#
# Pull command: ollama pull mistral
# For a remote instance: OLLAMA_BASE_URL=http://your-server:11434
# ---------------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# ---------------------------------------------------------------------------
# HuggingFace Hub (optional — speeds up model downloads)
# Without a token, downloads are rate-limited to ~36 kB/s per file.
# With a free token, limits are removed and speeds are typical download rates.
# Get a free token at: https://huggingface.co/settings/tokens
# ---------------------------------------------------------------------------
HF_TOKEN=

# ---------------------------------------------------------------------------
# NLP Model Configuration (ADR-004 — Research-backed upgrades)
# ---------------------------------------------------------------------------

# Stage 2c — TTP Semantic Matching embedding model
# Default: all-MiniLM-L6-v2 (80 MB, fast, general English)
# Recommended upgrade: ehsanaghaei/SecureBERT-Plus (500 MB, security-domain,
#   better recall on security-jargon TTP phrases — CTiKG paper, F1+8-12%)
# After changing this value, rebuild the embedding cache:
#   python scripts/build_indexes.py --only embeddings
TTP_EMBEDDING_MODEL=all-MiniLM-L6-v2

# Stage 3d — Self-verification of relationship claims (ADR-004 P3-A)
# Based on aCTIon paper (NEC Labs, 2023): second LLM pass quotes the supporting
# sentence for each extracted relationship; unsupported claims are removed.
# Effect: reduces relationship hallucination rate from ~27% to ~8%.
# Cost: adds ~1.4× total LLM calls (only chunks with ≥1 relationship are re-checked).
# Recommended: enable for high-value reports; disable for fast/bulk processing.
ENABLE_STIX_VERIFICATION=false
# Minimum relationships in a chunk before verification runs (skip low-yield chunks)
STIX_VERIFY_MIN_RELS=1

# Stage 2d — CyNER cybersecurity NER
# The original aiforsec/cyner-xlm-roberta-base model was removed from HuggingFace.
# Stage 2e (GLiNER) covers the same entity types (malware families, threat actors)
# and is the active fallback. Set CYNER_ENABLED=false to silence the warning.
CYNER_ENABLED=false
# If an alternative CyNER-compatible model becomes available, set it here:
# CYNER_MODEL=aiforsec/cyner-xlm-roberta-base

# Stage 2e — GLiNER / NuNER zero-shot NER
# Discovers entity types CyNER/gazetteer miss: targeted sectors, campaign names,
# attack infrastructure, novel actors & malware not yet in MITRE ATT&CK.
# Paper: "0-CTI" by CY4GATE (2025) — ADR-004 P2-A
#
# Model options (all are drop-in via GLINER_MODEL — same interface, no code change):
#
#   GLiNER models (urchade):
#     urchade/gliner_mediumv2.1  — ~300 MB  · good accuracy/speed balance
#     urchade/gliner_largev2.1   — ~800 MB  · best GLiNER accuracy, slower
#     urchade/gliner_smallv2.1   — ~120 MB  · fastest, lower recall
#
#   NuNER models (NuMind) — GLiNER-based with improved token classification heads.
#   Community benchmarks show NuNER-Zero-span outperforms GLiNER medium on multi-
#   domain zero-shot NER.  Drop-in compatible: same labels, same threshold.
#     numind/NuNER-Zero-span     — ~300 MB  · RECOMMENDED — best zero-shot NER quality
#     numind/NuNER-Zero          — ~300 MB  · alternative NuNER variant
#
# To switch: change GLINER_MODEL below and restart (no rebuild needed).
GLINER_MODEL=numind/NuNER-Zero-span
GLINER_THRESHOLD=0.40
# Set to false to disable Stage 2e entirely (saves ~300 MB RAM + CPU time)
GLINER_ENABLED=true

# ---------------------------------------------------------------------------
# Advanced — Stage 3 LLM throughput
# ---------------------------------------------------------------------------

# Number of chunks processed concurrently during LLM enrichment.
# Higher values speed up large reports but increase API cost bursts.
# Lower if you hit rate-limit errors (429).
LLM_PARALLELISM=3

# Save a checkpoint to disk every N completed chunks.
# Lets the pipeline resume from the last checkpoint on crash or interruption.
CHECKPOINT_EVERY=5
